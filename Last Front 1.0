local parts = {"Head", "UpperTorso", "HumanoidRootPart"}
local partIndex = 1

partBtn.MouseButton1Click:Connect(function()
    partIndex = partIndex % #parts + 1
    aimbotSettings.targetPart = parts[partIndex]
    partBtn.Text = parts[partIndex]
    partLabel.Text = "Target: " .. parts[partIndex]
end)

-- FOV Slider
createSlider("Aimbot FOV", aimbotScroll, 50, 500, 150, function(value)
    aimbotSettings.fov = value
end)

-- Smoothness Slider
createSlider("Smoothness", aimbotScroll, 0, 20, 5, function(value)
    aimbotSettings.smoothness = value
end)

-- ==================== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ====================
local contents = {
    [visualsBtn] = visualContent,
    [aimbotBtn] = aimbotContent,
    [miscBtn] = miscContent,
}

visualsBtn.MouseButton1Click:Connect(function()
    setActive(visualsBtn)
    for btn, content in pairs(contents) do
        content.Visible = (btn == visualsBtn)
    end
end)

aimbotBtn.MouseButton1Click:Connect(function()
    setActive(aimbotBtn)
    for btn, content in pairs(contents) do
        content.Visible = (btn == aimbotBtn)
    end
end)

miscBtn.MouseButton1Click:Connect(function()
    setActive(miscBtn)
    for btn, content in pairs(contents) do
        content.Visible = (btn == miscBtn)
    end
end)

-- Активируем Aimbot по умолчанию
setActive(aimbotBtn)
aimbotContent.Visible = true
visualContent.Visible = false

-- ==================== ПЕРЕТАСКИВАНИЕ ====================
local dragFrame = Instance.new("Frame")
dragFrame.Size = UDim2.new(1, 0, 0, 45)
dragFrame.BackgroundTransparency = 1
dragFrame.Parent = mainFrame

local dragging, dragStart, startPos
dragFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)
dragFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                     input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ==================== ГОРЯЧАЯ КЛАВИША ====================
game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.Insert then
        gui.Enabled = not gui.Enabled
    end
end)

print("✅ Часть 3 загружена! Меню полностью готово.")
print("Используй Insert для скрытия/показа.")
