aimbotScroll.ScrollBarImageColor3 = Color3.fromRGB(255, 50, 50)
aimbotScroll.Parent = aimbotContent

local aimbotList = Instance.new("UIListLayout")
aimbotList.Padding = UDim.new(0, 6)
aimbotList.Parent = aimbotScroll

-- Переменные аимбота
local aimbotSettings = {
    enabled = false,
    silent = false,
    fov = 150,
    smoothness = 5,
    targetPart = "Head", -- Head, HumanoidRootPart, UpperTorso
    teamCheck = false,
    visibilityCheck = false,
}

-- Функция получения целей Last Front
local function getAimbotTargets()
    local targets = {}
    
    -- Пробуем найти игроков через стандартный Players
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player then
            if aimbotSettings.teamCheck then
                -- Проверка команды (если есть Team)
                if plr.Team and player.Team and plr.Team == player.Team then
                    continue
                end
            end
            if plr.Character then
                local targetPart = plr.Character:FindFirstChild(aimbotSettings.targetPart)
                if targetPart then
                    table.insert(targets, {
                        player = plr,
                        part = targetPart,
                    })
                end
            end
        end
    end
    
    -- Для Last Front: поиск NPC/мобов
    -- Пробуем найти врагов в workspace
    pcall(function()
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
                local humanoid = obj.Humanoid
                if humanoid.Health > 0 then
                    local targetPart = obj:FindFirstChild(aimbotSettings.targetPart) or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                    if targetPart then
                        -- Проверяем, не является ли это игроком (уже добавлены)
                        local isPlayer = false
                        for _, t in pairs(targets) do
                            if t.part == targetPart then
                                isPlayer = true
                                break
                            end
                        end
                        if not isPlayer then
                            table.insert(targets, {
                                player = nil,
                                part = targetPart,
                            })
                        end
                    end
                end
            end
        end
    end)
    
    return targets
end

-- Функция проверки видимости
local function isVisible(targetPos)
    local camera = workspace.CurrentCamera
    local char = player.Character
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end
    
    local ray = Ray.new(camera.CFrame.Position, (targetPos - camera.CFrame.Position).Unit * 500)
    local hit = workspace:FindPartOnRay(ray, char)
    
    -- Упрощённая проверка
    if hit then
        local targetModel = hit:FindFirstAncestorOfClass("Model")
        if targetModel then
            return true -- Видимо
        end
    end
    return false
end

-- Aimbot loop
local aimbotConnection
local function updateAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    
    if not aimbotSettings.enabled then return end
    
    aimbotConnection = game:GetService("RunService").RenderStepped:Connect(function()
        local char = player.Character
        if not char then return end
        local camera = workspace.CurrentCamera
        
        local targets = getAimbotTargets()
        if #targets == 0 then return end
        
        -- Поиск ближайшей цели к прицелу
        local closest, closestDist = nil, aimbotSettings.fov
        local mousePos = camera.ViewportSize / 2
        
        for _, target in pairs(targets) do
            local pos, onScreen = camera:WorldToViewportPoint(target.part.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                if dist < closestDist then
                    -- Проверка видимости
                    if aimbotSettings.visibilityCheck then
                        if not isVisible(target.part.Position) then
                            continue
                        end
                    end
                    closestDist = dist
                    closest = target
                end
            end
        end
        
        if closest then
            local targetPos = closest.part.Position
            if aimbotSettings.silent then
                -- Silent Aim (меняем направление пули, не камеру)
                -- Для Silent Aim нужно взаимодействовать с системой оружия Last Front
                -- Это зависит от конкретной игры
                pcall(function()
                    -- Пробуем изменить направление через репликацию
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then
                        -- Разные методы для разных игр
                        local handle = tool:FindFirstChild("Handle") or tool:FindFirstChild("Barrel")
                        if handle then
                            -- Изменяем CFrame оружия для силент аима
                            local originalCF = handle.CFrame
                            handle.CFrame = CFrame.new(handle.Position, targetPos)
                            -- Возвращаем обратно почти сразу
                            task.wait()
                            pcall(function() handle.CFrame = originalCF end)
                        end
                    end
                end)
            else
                -- Обычный аимбот (плавное наведение)
                local aimCF = CFrame.new(camera.CFrame.Position, targetPos)
                if aimbotSettings.smoothness > 0 then
                    camera.CFrame = camera.CFrame:Lerp(aimCF, 1 / aimbotSettings.smoothness)
                else
                    camera.CFrame = aimCF
                end
            end
        end
    end)
end

-- Настройки аимбота
createToggle("Enable Aimbot", aimbotScroll, false, function(state)
    aimbotSettings.enabled = state
    updateAimbot()
end)

createToggle("Silent Aim", aimbotScroll, false, function(state)
    aimbotSettings.silent = state
end)

createToggle("Team Check", aimbotScroll, false, function(state)
    aimbotSettings.teamCheck = state
end)

createToggle("Visibility Check", aimbotScroll, false, function(state)
    aimbotSettings.visibilityCheck = state
end)

