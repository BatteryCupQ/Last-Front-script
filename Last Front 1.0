-- Переменные ESP
local espSettings = {
    boxes = true,
    skeleton = false,
    health = true,
    tracers = false,
    names = true,
    trail = false,
    trailColor = Color3.fromRGB(255, 50, 50)
}

local drawings = {}
local espEnabled = false

-- Очистка ESP
local function clearESP()
    for _, d in pairs(drawings) do
        pcall(function() d:Remove() end)
    end
    drawings = {}
end

-- Функция ESP
local function drawESP()
    clearESP()
    if not espEnabled then return end
    
    local camera = workspace.CurrentCamera
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = plr.Character:FindFirstChild("Humanoid")
            
            if head and hrp then
                local headPos, onScreen = camera:WorldToViewportPoint(head.Position)
                local hrpPos = camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen then
                    -- Boxes
                    if espSettings.boxes then
                        local boxSize = Vector2.new(40, 55)
                        local box = Drawing.new("Square")
                        box.Position = Vector2.new(headPos.X - boxSize.X/2, headPos.Y - boxSize.Y/2 - 5)
                        box.Size = boxSize
                        box.Color = Color3.fromRGB(255, 50, 50)
                        box.Thickness = 2
                        box.Filled = false
                        box.Visible = true
                        table.insert(drawings, box)
                    end
                    
                    -- Skeleton
                    if espSettings.skeleton and plr.Character then
                        local parts = {
                            {"Head", "UpperTorso"},
                            {"UpperTorso", "LowerTorso"},
                            {"UpperTorso", "LeftUpperArm"},
                            {"LeftUpperArm", "LeftLowerArm"},
                            {"LeftLowerArm", "LeftHand"},
                            {"UpperTorso", "RightUpperArm"},
                            {"RightUpperArm", "RightLowerArm"},
                            {"RightLowerArm", "RightHand"},
                            {"LowerTorso", "LeftUpperLeg"},
                            {"LeftUpperLeg", "LeftLowerLeg"},
                            {"LeftLowerLeg", "LeftFoot"},
                            {"LowerTorso", "RightUpperLeg"},
                            {"RightUpperLeg", "RightLowerLeg"},
                            {"RightLowerLeg", "RightFoot"},
                        }
                        for _, pair in ipairs(parts) do
                            local part1 = plr.Character:FindFirstChild(pair[1])
                            local part2 = plr.Character:FindFirstChild(pair[2])
                            if part1 and part2 then
                                local pos1 = camera:WorldToViewportPoint(part1.Position)
                                local pos2 = camera:WorldToViewportPoint(part2.Position)
                                local line = Drawing.new("Line")
                                line.From = Vector2.new(pos1.X, pos1.Y)
                                line.To = Vector2.new(pos2.X, pos2.Y)
                                line.Color = Color3.fromRGB(255, 255, 255)
                                line.Thickness = 1
                                line.Visible = true
                                table.insert(drawings, line)
                            end
                        end
                    end
                    
                    -- Health Bar
                    if espSettings.health and humanoid then
                        local hpPercent = humanoid.Health / humanoid.MaxHealth
                        local barBg = Drawing.new("Line")
                        barBg.From = Vector2.new(headPos.X - 22, headPos.Y - 38)
                        barBg.To = Vector2.new(headPos.X + 22, headPos.Y - 38)
                        barBg.Color = Color3.fromRGB(50, 50, 50)
                        barBg.Thickness = 3
                        barBg.Visible = true
                        table.insert(drawings, barBg)
                        
                        local barFill = Drawing.new("Line")
                        barFill.From = Vector2.new(headPos.X - 22, headPos.Y - 38)
                        barFill.To = Vector2.new(headPos.X - 22 + (44 * hpPercent), headPos.Y - 38)
                        barFill.Color = hpPercent > 0.5 and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
                        barFill.Thickness = 3
                        barFill.Visible = true
                        table.insert(drawings, barFill)
                    end
                    
                    -- Tracers
                    if espSettings.tracers then
                        local line = Drawing.new("Line")
                        line.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        line.To = Vector2.new(headPos.X, headPos.Y)
                        line.Color = espSettings.trailColor
                        line.Thickness = 1
                        line.Visible = true
                        table.insert(drawings, line)
                    end
                    
                    -- Names
                    if espSettings.names then
                        local name = Drawing.new("Text")
                        name.Text = plr.Name
                        name.Position = Vector2.new(headPos.X, headPos.Y - 45)
                        name.Size = 12
                        name.Color = Color3.fromRGB(255, 255, 255)
                        name.Center = true
                        name.Visible = true
                        table.insert(drawings, name)
                    end
                end
            end
            
            -- Trail (рисуется даже если не на экране, в мире)
            if espSettings.trail and plr.Character and hrp then
                -- Trail логика сложнее, тут просто маркер
            end
        end
    end
end

-- Обновление ESP каждый кадр
game:GetService("RunService").RenderStepped:Connect(function()
    if espEnabled then
        drawESP()
    end
end)

