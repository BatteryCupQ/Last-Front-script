-- Кнопки категорий
local function createCategoryButton(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 36)
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.AutoButtonColor = false
    btn.Parent = leftPanel

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn

    return btn
end

local visualsBtn = createCategoryButton("🎯 Visuals", 60)
local aimbotBtn = createCategoryButton("🔫 Aimbot", 102)
local miscBtn = createCategoryButton("⚙ Misc", 144)

local function setActive(btn)
    for _, b in pairs({visualsBtn, aimbotBtn, miscBtn}) do
        b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        b.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    btn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

